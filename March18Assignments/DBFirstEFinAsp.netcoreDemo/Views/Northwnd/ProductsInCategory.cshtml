@model IEnumerable<DBFirstEFinAsp.netcoreDemo.Models.ProdCat>

@{
    ViewData["Title"] = "ProductsInCategory";
}

<h1>Products In Category</h1>

<div class="container">
    <div class="row">
        <div class="col-lg-9">
            <h2>Products in category</h2>
        </div>
        <form method="get" action="/Northwnd/ProductsInCategory">
            <div class="col-lg-2">
                <input type="text" id="category" name="categoryname" class="form-control"/> <!--name atrribute should match with the paramter passed in ProductsInCategory Actioin Result-->
            </div>
            <div class="col-lg-1">
                <input type="submit" id="Searchproducts" class="btn btn-primary" value="search"/>
            </div>
        </form>
    </div>
</div>
@if (Model.Count() == 0)
{
    <table>
        <tr>
            <td>No Products found</td>
        </tr>
    </table>
}
else
{
    <div class="row">
        <div class="col-lg-12"></div>
        <table id="prodlist" width="80%" cellpadding="5" cellspacing="5"
                    class="table-stripped table-hover">
            <thead>
                <tr>
                    <th style="padding:15px">Prodname</th>
                    <th style="padding:15px">Categoryname</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var prod in Model)
                {
                    <tr>
                        <td style="padding:15px">@prod.prodname</td>
                        <td style="padding:15px">@prod.catname</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}